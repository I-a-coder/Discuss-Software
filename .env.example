# Copy to .env.local and fill in values

DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI assistant (Groq free tier: https://console.groq.com)
AI_API_KEY=""
AI_API_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"
# Optional: OpenAI key for Whisper transcription of meeting recordings
OPENAI_API_KEY=""

# Used for encrypting stored notes and messages at rest
ENCRYPTION_KEY="your-32-char-minimum-encryption-key"

# Email notifications via Resend (https://resend.com — free tier: 3,000 emails/month)
# 1. Sign up at https://resend.com
# 2. Create an API key at https://resend.com/api-keys
# 3. (Optional) Verify your domain at https://resend.com/domains for a custom from address
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Yusi Discuss <onboarding@resend.dev>"

# --- Calendar Sync (optional) ------------------------------------------------
# Organizers can connect Google Calendar or Microsoft 365 so scheduled meetings
# automatically appear on their calendar and invitees receive real calendar invites.
#
# Google Calendar
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3000/api/calendar-sync/callback
# 4. Enable the "Google Calendar API" in APIs & Services → Library
# 5. Request scope: https://www.googleapis.com/auth/calendar.events
# NOTE: Use a separate OAuth client from GOOGLE_CLIENT_ID (login) OR add the
#       calendar scope + redirect URI to your existing client.
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""

# Microsoft 365 / Outlook
# 1. Go to https://portal.azure.com → App registrations → New registration
# 2. Set redirect URI: http://localhost:3000/api/calendar-sync/callback
# 3. Add API permission: Microsoft Graph → Delegated → Calendars.ReadWrite
# 4. Create a client secret under Certificates & secrets
# MICROSOFT_CALENDAR_TENANT: use "common" for both personal + work accounts,
#   or your tenant ID to restrict to a single Azure AD tenant.
MICROSOFT_CALENDAR_CLIENT_ID=""
MICROSOFT_CALENDAR_CLIENT_SECRET=""
MICROSOFT_CALENDAR_TENANT="common"
