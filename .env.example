# Copy to .env.local and fill in values

DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI assistant (Groq free tier: https://console.groq.com)
AI_API_KEY=""
AI_API_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"
# Optional: OpenAI key for Whisper transcription of meeting recordings
OPENAI_API_KEY=""

# Used for encrypting stored notes and messages at rest
ENCRYPTION_KEY="your-32-char-minimum-encryption-key"
